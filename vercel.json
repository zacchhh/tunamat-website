{
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/tunamat", "destination": "/tunamat.html" },
    { "source": "/roadmap", "destination": "/roadmap.html" },
    { "source": "/feedback", "destination": "/feedback.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/tunamat/webapp", "destination": "/app/index.html" },
    { "source": "/tunamat/webapp/(.*)", "destination": "/app/index.html" },
    { "source": "/app/(.*)", "destination": "/app/index.html" }
  ]
}
