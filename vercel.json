{
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/tunamat", "destination": "/tunamat.html" },
    { "source": "/roadmap", "destination": "/roadmap.html" },
    { "source": "/feedback", "destination": "/feedback.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/blog/:slug", "destination": "/blog-post.html" },
    { "source": "/tunamat/flowbuilder", "destination": "/app/index.html" },
    { "source": "/tunamat/flowbuilder/(.*)", "destination": "/app/index.html" },
    { "source": "/tunamat/webapp", "destination": "/tunamat/flowbuilder" },
    { "source": "/tunamat/webapp/(.*)", "destination": "/tunamat/flowbuilder" },
    { "source": "/app/(.*)", "destination": "/app/index.html" }
  ]
}
